# ============================================
# Supply Chain Risk Intelligence v0.9.0 - 環境変数
# ============================================

# --- Database ---
# SQLite (development)
DATABASE_URL=sqlite:///./data/risk.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/supply_risk
# SQLite path for timeseries data
SQLITE_DB_PATH=./data/timeseries.db

# --- 必須API（無料枠あり） ---

# Google BigQuery (GDELT用) - 無料枠 月1TB
# https://cloud.google.com/bigquery/pricing
BIGQUERY_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# --- オプションAPI（なくても動作する） ---

# AISHub - AIS船舶追跡 (https://www.aishub.net/ で無料アカウント作成)
AISHUB_API_KEY=

# NASA FIRMS - 衛星火災検知 (https://firms.modaps.eosdis.nasa.gov/api/ で無料MAP_KEY取得)
NASA_FIRMS_MAP_KEY=

# ACLED - 武力紛争データ (https://acleddata.com/register/ で無料アカウント作成)
ACLED_API_KEY=
ACLED_EMAIL=

# ReliefWeb - 人道危機レポート (https://apidoc.reliefweb.int/ でappname申請)
RELIEFWEB_APPNAME=

# 法人番号API (https://www.houjin-bangou.nta.go.jp/webapi/ で無料取得)
HOUJIN_API_KEY=

# Caselaw MCP (既存インフラ)
CASELAW_MCP_URL=https://caselaw.patent-space.dev/mcp

# --- APIキー不要で動作するデータソース ---
# GDACS (災害アラート) - キー不要
# USGS (地震データ) - キー不要
# BMKG (インドネシア地震) - キー不要
# IMF PortWatch (港湾途絶) - キー不要
# World Bank (経済指標) - キー不要
# Frankfurter/ECB (為替レート) - キー不要
# Disease.sh (感染症データ) - キー不要
# OpenSanctions (制裁統合) - キー不要
# INFORM Risk Index (災害リスク) - キー不要
# SECO (スイス制裁) - キー不要
# OFSI (英国制裁) - キー不要
# DFAT (豪州制裁) - キー不要
# Climate TRACE (https://climatetrace.org/) - キー不要
# ND-GAIN (https://gain.nd.edu/) - キー不要
# GloFAS (https://www.globalfloods.eu/) - キー不要
# WRI Aqueduct (https://www.wri.org/aqueduct) - キー不要
# OONI (https://ooni.org/) - キー不要
# CISA KEV (https://www.cisa.gov/known-exploited-vulnerabilities-catalog) - キー不要
# ITU ICT (https://www.itu.int/) - キー不要

# --- サーバー設定 ---
MCP_HOST=0.0.0.0
MCP_PORT=8001
API_HOST=0.0.0.0
API_PORT=8000

# --- 時系列DB設定 ---
TIMESERIES_DB_PATH=./data/timeseries.db
SCHEDULER_INTERVAL_HOURS=6
CRITICAL_UPDATE_INTERVAL_HOURS=1

# --- Docker/デプロイ設定 ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Worker count for uvicorn (production)
WORKERS=1
# Enable CORS for specific origins (comma-separated, default: *)
CORS_ORIGINS=*
# WebSocket alert broadcast interval (seconds)
WS_BROADCAST_INTERVAL=30
